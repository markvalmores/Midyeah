{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User custom channel details and credentials",
      "type": "object",
      "properties": {
        "username": { "type": "string", "description": "Display user identifier handle" },
        "email": { "type": "string", "format": "email", "description": "Unique user email address" },
        "channelName": { "type": "string", "description": "Creative channel brand name" },
        "channelUrl": { "type": "string", "description": "Unique URL search handle" },
        "bio": { "type": "string", "description": "Channel biography details" },
        "avatarUrl": { "type": "string", "description": "User headshot visual image source URL" },
        "coverUrl": { "type": "string", "description": "User channel cover visual banner source URL" },
        "subscribersCount": { "type": "integer", "description": "Simulated or actual subscriber milestone ticker" },
        "gcash": { "type": "string", "description": "GCash mobile wallet withdrawal path mapping" },
        "paypal": { "type": "string", "description": "PayPal credentials path mapping" }
      },
      "required": ["username", "email", "channelName", "channelUrl", "avatarUrl"]
    },
    "Video": {
      "title": "Video",
      "description": "Video metadata representation on the global network",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique globally available UUID mapping" },
        "title": { "type": "string", "description": "Creative video title metadata" },
        "description": { "type": "string", "description": "Extended content summary overview" },
        "videoUrl": { "type": "string", "description": "Asset play fallback link or reconstruction node pointer" },
        "category": { "type": "string", "enum": ["normal", "movie", "rental"], "description": "Monetization tier category" },
        "rentalPrice": { "type": "number", "description": "Optional currency pricing modifier" },
        "rentalPeriod": { "type": "string", "description": "Optional periodic validation tier" },
        "is360": { "type": "boolean", "description": "Interactive gyroscope visual state tracker" },
        "uploadDate": { "type": "string", "description": "Localized calendar record anchor" },
        "creatorEmail": { "type": "string", "description": "Email identifier of the creator" },
        "creatorName": { "type": "string", "description": "Display brand name of the uploader" },
        "creatorAvatar": { "type": "string", "description": "Avatar of the uploader" },
        "views": { "type": "integer", "description": "Consolidated watch ticker" },
        "likes": { "type": "integer", "description": "User approval metrics" },
        "dislikes": { "type": "integer", "description": "Dislike metrics" },
        "duration": { "type": "number", "description": "Length in standard seconds" },
        "hasVideoData": { "type": "boolean", "description": "Flag indicating if peer-to-peer chunking storage is present in the database" }
      },
      "required": ["id", "title", "videoUrl", "category", "uploadDate", "creatorEmail", "duration"]
    },
    "VideoChunk": {
      "title": "VideoChunk",
      "description": "Fragment representing chunked video binary data streams",
      "type": "object",
      "properties": {
        "index": { "type": "integer", "description": "Ascending fragment compilation anchor" },
        "data": { "type": "string", "description": "Raw Base64 encoded binary video content segment" }
      },
      "required": ["index", "data"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Global user social feedback and chat strings under uploaded videos",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Comment ID" },
        "videoId": { "type": "string", "description": "Belongs to Video ID" },
        "username": { "type": "string", "description": "Creator display handle" },
        "avatarUrl": { "type": "string", "description": "Creator profile headshot" },
        "text": { "type": "string", "description": "Text body feedback details" },
        "timestamp": { "type": "string", "description": "Calendar capture stamp" },
        "likes": { "type": "integer", "description": "Consolidated comment approval counter" }
      },
      "required": ["id", "videoId", "username", "text", "timestamp"]
    },
    "DiscordMessage": {
      "title": "DiscordMessage",
      "description": "Global community chat message details",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique globally available message ID" },
        "username": { "type": "string", "description": "Sender username" },
        "avatarUrl": { "type": "string", "description": "Sender avatar visual link" },
        "text": { "type": "string", "description": "Message chat string content" },
        "timestamp": { "type": "string", "description": "ISO calendar snapshot" }
      },
      "required": ["id", "username", "text", "timestamp"]
    },
    "Playlist": {
      "title": "Playlist",
      "description": "Custom curated video collections for viewers",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique playlist identifier ID" },
        "name": { "type": "string", "description": "Curator assigned title text" },
        "ownerEmail": { "type": "string", "description": "Email address of the owner" },
        "videoIds": {
          "type": "array",
          "description": "Sequential array collection of included video identifier hashes"
        },
        "createdAt": { "type": "string", "description": "Creation timestamp entry tracking" }
      },
      "required": ["id", "name", "ownerEmail", "videoIds", "createdAt"]
    },
    "DonationRecord": {
      "title": "DonationRecord",
      "description": "A record of voluntary donation support contributed by users",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique donation hash ID" },
        "donorName": { "type": "string", "description": "Voluntary profile donor alias" },
        "amount": { "type": "number", "description": "Donated value in USD" },
        "message": { "type": "string", "description": "Cheering message text description" },
        "target": { "type": "string", "description": "Target of support: owner, charity, church, or people" },
        "timestamp": { "type": "string", "description": "ISO calendar snapshot" }
      },
      "required": ["id", "donorName", "amount", "message", "target", "timestamp"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "User subscription mappings for following creators",
      "type": "object",
      "properties": {
        "followerEmail": { "type": "string", "description": "Follower email identifier" },
        "followedEmail": { "type": "string", "description": "Followed creator email identifier" },
        "timestamp": { "type": "string", "description": "Timestamp when matching took place" }
      },
      "required": ["followerEmail", "followedEmail", "timestamp"]
    },
    "LikeDislike": {
      "title": "LikeDislike",
      "description": "User persistent like or dislike choices on videos",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User email or hardware fingerprint identifier" },
        "videoId": { "type": "string", "description": "Associated Video ID" },
        "type": { "type": "string", "enum": ["like", "dislike"], "description": "Choice type" },
        "timestamp": { "type": "string", "description": "ISO calendar snapshot" }
      },
      "required": ["userId", "videoId", "type", "timestamp"]
    },
    "VideoReaction": {
      "title": "VideoReaction",
      "description": "User persistent emoji reaction choices on videos",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User email or hardware fingerprint identifier" },
        "videoId": { "type": "string", "description": "Associated Video ID" },
        "type": { "type": "string", "description": "Emoji category selected" },
        "timestamp": { "type": "string", "description": "ISO calendar snapshot" }
      },
      "required": ["userId", "videoId", "type", "timestamp"]
    },
    "UsageTracker": {
      "title": "UsageTracker",
      "description": "Tracks session duration on MidYeah",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User email" },
        "totalSeconds": { "type": "integer", "description": "Total usage duration in seconds" },
        "lastActive": { "type": "string", "description": "Last ISO timestamp of activity" }
      },
      "required": ["userId", "totalSeconds", "lastActive"]
    },
    "BannedEmail": {
      "title": "BannedEmail",
      "description": "System records of banned user emails and deletion traces",
      "type": "object",
      "properties": {
        "banned": { "type": "boolean", "description": "Strict ban status constraint" },
        "bannedAt": { "type": "string", "description": "ISO calendar stamp capture" }
      },
      "required": ["banned", "bannedAt"]
    }
  },
  "firestore": {
    "/profiles/{email}": {
      "schema": "UserProfile",
      "description": "User specific custom channel configurations and payout routes"
    },
    "/global_videos/{videoId}": {
      "schema": "Video",
      "description": "Global directory of creative user video postings"
    },
    "/global_videos/{videoId}/chunks/{chunkId}": {
      "schema": "VideoChunk",
      "description": "Subcollection housing binary streaming chunks for full serverless global distribution"
    },
    "/global_videos/{videoId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Subcollection housing social comments for specific upload entities"
    },
    "/discord_messages/{messageId}": {
      "schema": "DiscordMessage",
      "description": "Global community real-time discord chat workspace"
    },
    "/playlists/{playlistId}": {
      "schema": "Playlist",
      "description": "Subscriber dynamic curated video playlists"
    },
    "/donations/{donationId}": {
      "schema": "DonationRecord",
      "description": "Donations contributed toward owners, charities, churches, and needy people"
    },
    "/subscriptions/{subId}": {
      "schema": "Subscription",
      "description": "Mappings which describe subscriber counts dynamically"
    },
    "/group_memberships/{membershipId}": {
      "description": "User memberships in creator communities"
    },
    "/likes_dislikes/{likeId}": {
      "schema": "LikeDislike",
      "description": "Persistent record keeping user specific standard likes and dislikes"
    },
    "/video_reactions/{reactId}": {
      "schema": "VideoReaction",
      "description": "Persistent record keeping user specific social reaction emojis"
    },
    "/usage_trackers/{email}": {
      "schema": "UsageTracker",
      "description": "Tracks total time usage on MidYeah"
    },
    "/banned_emails/{email}": {
      "schema": "BannedEmail",
      "description": "Directory of accounts marked permanently banned by Gemini AI content moderation"
    }
  }
}
