rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net: Default-deny all unmapped operations
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(email) {
      return isSignedIn() && request.auth.token.email == email;
    }

    function isValidId(id) {
      return id is string && id.size() <= 256 && id.matches('^[a-zA-Z0-9_\\-\\.\\@\\+]+$');
    }

    // Form/payload schema validators
    function isValidUserProfile(data) {
      return data.username is string && data.username.size() <= 100
          && data.email is string && data.email.size() <= 100
          && data.channelName is string && data.channelName.size() <= 100
          && data.channelUrl is string && data.channelUrl.size() <= 100
          && (!('subscribersCount' in data) || data.subscribersCount == null || data.subscribersCount is int || data.subscribersCount is number)
          && (!('rentalPaid' in data) || data.rentalPaid == null || data.rentalPaid is bool)
          && (!('rentalExpiry' in data) || data.rentalExpiry == null || data.rentalExpiry is string);
    }

    function isValidVideo(data) {
      return data.id is string && data.id.size() <= 128
          && data.title is string && data.title.size() <= 200
          && data.videoUrl is string && data.videoUrl.size() <= 2048
          && data.category in ['normal', 'movie', 'rental']
          && (data.duration is number || data.duration is string)
          && data.creatorEmail is string
          && (!('likes' in data) || data.likes == null || data.likes is int || data.likes is number)
          && (!('dislikes' in data) || data.dislikes == null || data.dislikes is int || data.dislikes is number)
          && (!('views' in data) || data.views == null || data.views is int || data.views is number)
          && (!('reactions' in data) || data.reactions == null || data.reactions is map);
    }

    function isValidVideoChunk(data) {
      return data.index is int
          && data.data is string && data.data.size() <= 1100000; // Limit base64 chunk to ~1.1MB
    }

    function isValidComment(data) {
      return data.id is string
          && data.videoId is string
          && data.username is string && data.username.size() <= 100
          && data.text is string && data.text.size() <= 10000;
    }

    function isValidDiscordMessage(data) {
      return data.id is string
          && data.username is string && data.username.size() <= 100
          && data.text is string && data.text.size() <= 10000;
    }

    function isValidPlaylist(data) {
      return data.id is string
          && data.name is string && data.name.size() <= 100
          && data.ownerEmail is string && data.ownerEmail.size() <= 100
          && data.videoIds is list && data.videoIds.size() <= 500;
    }

    function isValidDonation(data) {
      return data.id is string
          && data.donorName is string && data.donorName.size() <= 100
          && data.amount is number
          && data.message is string && data.message.size() <= 10000
          && data.target is string && data.target.size() <= 100;
    }

    function isValidLikeDislike(data) {
      return data.userId is string && data.userId.size() <= 128
          && data.videoId is string && data.videoId.size() <= 128
          && data.type in ['like', 'dislike'];
    }

    function isValidVideoReaction(data) {
      return data.userId is string && data.userId.size() <= 128
          && data.videoId is string && data.videoId.size() <= 128
          && data.type is string && data.type.size() <= 100;
    }

    function isGuest() {
      return isSignedIn() && request.auth.token.email == "guest@midyeah.com";
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "mdv4244@gmail.com";
    }

    // 2. User Profiles mapping
    match /profiles/{email} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner(email) && isValidUserProfile(request.resource.data);
      allow update: if (isSignedIn() && isOwner(email) && isValidUserProfile(request.resource.data))
                    || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['subscribersCount']));
      allow delete: if isSignedIn() && (isOwner(email) || isAdmin());
    }

    // 3. Global Videos mapping
    match /global_videos/{videoId} {
      allow read: if true; // Public list viewing allowed
      allow create: if isSignedIn() && !isGuest() && isValidId(videoId) 
                    && request.resource.data.creatorEmail == request.auth.token.email
                    && isValidVideo(request.resource.data);
      allow update: if isValidId(videoId)
                    && ( 
                      (isSignedIn() && !isGuest() && resource.data.creatorEmail == request.auth.token.email) || 
                      (isSignedIn() && !isGuest() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'likes', 'dislikes', 'reactions']))
                    )
                    && isValidVideo(request.resource.data);
      allow delete: if isSignedIn() && (isAdmin() || (resource.data.creatorEmail == request.auth.token.email && !isGuest()));

      // Chunks subcollection
      match /chunks/{chunkId} {
        allow read: if true; // Playback allowed publically
        allow create, update: if isSignedIn() 
                              && isValidId(chunkId)
                              && get(/databases/$(database)/documents/global_videos/$(videoId)).data.creatorEmail == request.auth.token.email
                              && isValidVideoChunk(request.resource.data);
        allow delete: if isSignedIn() && isValidId(chunkId)
                      && (isAdmin() || get(/databases/$(database)/documents/global_videos/$(videoId)).data.creatorEmail == request.auth.token.email);
      }

      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true; // Comments can be read globally
        allow create: if isSignedIn() && !isGuest() && isValidId(commentId)
                      && isValidComment(request.resource.data);
        allow update: if isSignedIn() && !isGuest() && isValidId(commentId)
                      && (resource.data.username == request.auth.token.name || get(/databases/$(database)/documents/global_videos/$(videoId)).data.creatorEmail == request.auth.token.email);
        allow delete: if isSignedIn() && !isGuest() && isValidId(commentId)
                      && (
                        isAdmin() ||
                        resource.data.username == request.auth.token.name || 
                        get(/databases/$(database)/documents/global_videos/$(videoId)).data.creatorEmail == request.auth.token.email
                      );
      }
    }

    // 4. Discord Community Messages
    match /discord_messages/{messageId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(messageId) && isValidDiscordMessage(request.resource.data);
      allow update, delete: if false;
    }

    // 4b. Profile Group Messages
    match /group_messages/{messageId} {
      allow read: if true;
      allow create: if isSignedIn() && !isGuest() && isValidId(messageId) && isValidDiscordMessage(request.resource.data) && request.resource.data.groupId is string;
      allow update, delete: if false;
    }

    // 5. Saved Custom Curator Playlists
    match /playlists/{playlistId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(playlistId) 
                    && request.resource.data.ownerEmail == request.auth.token.email
                    && isValidPlaylist(request.resource.data);
      allow update: if isSignedIn() && isValidId(playlistId)
                    && resource.data.ownerEmail == request.auth.token.email
                    && request.resource.data.ownerEmail == request.auth.token.email
                    && isValidPlaylist(request.resource.data);
      allow delete: if isSignedIn() && isValidId(playlistId) && resource.data.ownerEmail == request.auth.token.email;
    }

    // 6. Transparent Donation Audit & Ledger Records
    match /donations/{donationId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(donationId) && isValidDonation(request.resource.data);
      allow update, delete: if false;
    }

    // 7. Subscriptions mappings
    match /subscriptions/{subId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn() && !isGuest() && isValidId(subId);
    }

    // 8. Group Memberships
    match /group_memberships/{membershipId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn() && !isGuest() && isValidId(membershipId);
    }

    // 9. Persistent Likes/Dislikes
    match /likes_dislikes/{likeId} {
      allow read: if true;
      allow create, update: if isSignedIn() && !isGuest() && isValidId(likeId) && isValidLikeDislike(request.resource.data);
      allow delete: if isSignedIn() && !isGuest() && isValidId(likeId);
    }

    // 10. Persistent Video Reactions
    match /video_reactions/{reactId} {
      allow read: if true;
      allow create, update: if isSignedIn() && !isGuest() && isValidId(reactId) && isValidVideoReaction(request.resource.data);
      allow delete: if isSignedIn() && !isGuest() && isValidId(reactId);
    }

    // 11. Messenger Private/Group Messages
    match /messenger_messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && !isGuest() && isValidId(messageId);
      allow update: if false;
      allow delete: if isSignedIn() && !isGuest() && isValidId(messageId);
    }

    // 12. Messenger Chat Custom Settings
    match /messenger_settings/{settingId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && !isGuest() && isValidId(settingId);
      allow delete: if false;
    }

    // 13. Messenger Connections / Friendships
    match /friendships/{friendId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && !isGuest() && isValidId(friendId);
      allow delete: if isSignedIn() && !isGuest() && isValidId(friendId);
    }

    // 14. Messenger Group Chats Circles
    match /group_chats/{groupId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && !isGuest() && isValidId(groupId);
      allow delete: if isSignedIn() && !isGuest() && isValidId(groupId);
    }

    // 15. Creator Premium Memberships (Membership+)
    match /memberships/{membershipId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && !isGuest() && isValidId(membershipId);
      allow delete: if isSignedIn() && !isGuest() && isValidId(membershipId);
    }

    // 16. Members+ Exclusive Feed
    match /members_plus_posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && !isGuest() && isValidId(postId);
      allow update, delete: if isSignedIn() && !isGuest() && isValidId(postId) && (request.auth.token.email == resource.data.authorEmail);
    }

    // 17. Members+ Community Settings (Wallpaper, etc.)
    match /members_plus_settings/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && !isGuest() && (request.auth.token.email == userId);
    }

  }
}
